/*
 * ICM20602 + SSD1306 add-on for the 100ASK i.MX6ULL board DTS files.
 *
 * Audited base files:
 *   100ask_imx6ull_mini.dts
 *   100ask_imx6ull-14x14.dts
 *
 * Both base files already enable ECSPI1 and I2C1 and provide their bus
 * pinctrl and GPIO chip-select definitions.  Keep those board definitions
 * unchanged and add only the two client devices plus a candidate DRDY pad.
 * See README.md before wiring: CSI_DATA02 must be confirmed at the board
 * connector/schematic before this fragment is deployed.
 */

#include <dt-bindings/interrupt-controller/irq.h>

&iomuxc {
	imx6ull-imu-oled {
		pinctrl_icm20602_drdy: icm20602drdygrp {
			fsl,pins = <
				/* Matches the pad style used by the board's ICM20608 IRQ. */
				MX6UL_PAD_CSI_DATA02__GPIO4_IO23 0x000010B0
			>;
		};
	};
};

&ecspi1 {
	icm20602_imu: imu@0 {
		compatible = "invensense,icm20602";
		reg = <0>;
		spi-max-frequency = <8000000>;

		/* No spi-cpol/spi-cpha properties: SPI mode 0. */
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_icm20602_drdy>;
		interrupt-parent = <&gpio4>;
		interrupts = <23 IRQ_TYPE_EDGE_RISING>;

		status = "okay";
	};
};

&i2c1 {
	ssd1306_oled: oled@3c {
		compatible = "myvendor,ssd1306";
		reg = <0x3c>;
		status = "okay";
	};
};
